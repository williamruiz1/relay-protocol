{
  "$comment": "Planning surface definitions. The Stop hook reads this file to know which surfaces to check. Copy to <workspace>/.claude/protocol-config.json and customize.",
  "surfaces": [
    {
      "name": "handoff",
      "label": "Handoff log",
      "path": "docs/handoffs/",
      "match": "prefix"
    },
    {
      "name": "tracker",
      "label": "Workstream tracker",
      "path": ".claude/TRACKER.md",
      "match": "exact"
    },
    {
      "name": "history",
      "label": "Session history",
      "path": ".claude/session-history.md",
      "match": "exact",
      "exemptable": true
    }
  ],
  "sourcePatterns": ["^(src/|lib/|app/)"],
  "sourceExclusions": [],
  "$exemption_docs": "Add \"exemptable\": true to any surface that can be skipped on a per-session basis. To exempt during a session, create .claude/session-config.json with { \"exemptSurfaces\": [\"<name>\", ...], \"reason\": \"...\" }. See docs/adr-001-exemption-mechanism.md."
}
